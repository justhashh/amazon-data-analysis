import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt

st.title("Amazon Spending Analysis")

amazonorders = st.file_uploader(
    "Upload a File:",
    type=["csv"]
)

if amazonorders is not None:

    # Read CSV
    df = pd.read_csv(amazonorders)

    st.write(df.head())

    # Cleaning
    df["Total Charged"] = (
        df["Total Charged"]
        .str.replace('$', '', regex=False)
        .astype(float)
    )

    df["Tax Charged"] = (
        df["Tax Charged"]
        .str.replace('$', '', regex=False)
        .astype(float)
    )

    # Metrics
    total_spent = df["Total Charged"].sum()

    average_order = df["Total Charged"].mean()

    total_tax = df["Tax Charged"].sum()

    st.metric(
        "Total Money Spent",
        f"${total_spent:.2f}"
    )

    st.metric(
        "Average Order Value",
        f"${average_order:.2f}"
    )

    st.metric(
        "Total Tax Paid",
        f"${total_tax:.2f}"
    )

    # Graph
    daily_orders = df.groupby(
        "Order Date"
    )["Total Charged"].sum()

    fig, ax = plt.subplots(figsize=(10, 5))

    daily_orders.plot(ax=ax)

    plt.xticks(rotation=45)

    st.pyplot(fig)

else:
    st.warning("Please upload a CSV file.")
